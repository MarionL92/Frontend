{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://backend-pfe-utbn.onrender.com/api/$1" },
    { "source": "/auth/(.*)", "destination": "https://backend-pfe-utbn.onrender.com/auth/$1" },
    { "source": "/health", "destination": "https://backend-pfe-utbn.onrender.com/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
